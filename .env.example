# Ocean Intel — environment template
# Copy to .env (which is gitignored) and fill values for local dev.
# NONE of these are required for the public-data scrapers — included for the
# refresh harness alerting (Rules 16, 17, 19).

# Optional contact email used in scraper User-Agent strings.
SCRAPER_CONTACT_EMAIL=infinitygauntletllc@gmail.com

# Telegram alerting for the refresh harness (Rule 16, 17, 19). When unset,
# alerts log to data/raw/refresh.log and (for staleness/regression) write to
# STALE_ALERT.txt in repo root.
#
# Bot is @Xcerebrobot. To get TELEGRAM_USER_ID, message @userinfobot on
# Telegram. To get TELEGRAM_BOT_TOKEN, message @BotFather and request the
# token for the existing @Xcerebrobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
