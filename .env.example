# Ocean Intel — environment template
# Copy to .env (which is gitignored) and fill values for local dev.
# NONE of these are required for the public-data scrapers — included for future
# auth-gated NJ sources that may need credentials.

# Optional contact email used in scraper User-Agent strings.
SCRAPER_CONTACT_EMAIL=infinitygauntletllc@gmail.com

# Optional Telegram bot for OpenClaw refresh alerts (see OPERATIONS.md).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
